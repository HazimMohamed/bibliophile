## Hosted backend URL for Capacitor/mobile and production web builds.
## Leave unset for local web dev to use Vite's /api proxy.
VITE_API_BASE_URL=https://your-api.example.com

## Android-specific builds can use a separate mode-specific file:
## .env.android -> used by `npm run build:android`
## Our Android dev setup points this at a Windows-side relay like
## http://10.0.2.2:8787/api so the emulator does not need direct tailnet access.

## Optional: surface the hidden network diagnostics lab again.
VITE_SHOW_CONNECTION_LAB=false
